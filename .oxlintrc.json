{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "style": "error"
  },
  "rules": {
    "typescript/consistent-type-definitions": ["error", "type"],
    "typescript/explicit-member-accessibility": [
      "error",
      {
        "accessibility": "no-public"
      }
    ],
    "prefer-template": "error"
  }
}
