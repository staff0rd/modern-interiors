{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "style": "error"
  },
  "rules": {
    "typescript/consistent-type-definitions": ["error", "type"],
    "typescript/explicit-member-accessibility": [
      "error",
      {
        "accessibility": "no-public"
      }
    ],
    "prefer-template": "error",
    // Temporarily disabled: its member-syntax order conflicts with the editor's
    // `source.organizeImports.oxc`, and the rule's --fix is unreliable (oxc-project/oxc#13316),
    // so leaving it on makes `assist verify` fail on import order. Tracked in assist backlog #444.
    "sort-imports": "off"
  }
}
